networks:
  servarr:
    external: true
    
services:
  recyclarr:
    image: ghcr.io/recyclarr/recyclarr:8
    read_only: true
    tmpfs: /tmp
    security_opt: ['no-new-privileges:true']
    container_name: recyclarr
    networks:
      - servarr
    restart: unless-stopped
    user: 1050:1050
    environment:
      - TZ=Europe/London
      - RECYCLARR_CONFIG_DIR=/config
      - RECYCLARR_DATA_DIR=/data
    volumes:
      - /srv/recyclarr/config:/config
      - /srv/recyclarr/data:/data
