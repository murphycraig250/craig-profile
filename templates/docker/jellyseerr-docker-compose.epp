networks:
  servarr:
    external: true

services:
  jellyseerr:
    image: fallenbagel/jellyseerr:latest
    container_name: jellyseerr
    networks:
      - servarr
    environment:
      - LOG_LEVEL=info
      - TZ=Europe/London
      - PUID=1000
      - PGID=1000
    ports:
      - 5055:5055
    volumes:
      - /srv/jellyseerr/config:/app/config
    restart: unless-stopped
