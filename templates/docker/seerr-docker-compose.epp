networks:
  servarr:
    external: true

services:
  seerr:
    image: ghcr.io/seerr-team/seerr:latest
    container_name: seerr
    networks:
      - servarr
    environment:
      - LOG_LEVEL=info
      - TZ=Europe/London
      - PUID=1050
      - PGID=1050
    ports:
      - 5055:5055
    volumes:
      - /srv/seerr/config:/app/config
    restart: unless-stopped
