networks:
  servarrnetwork:
    external: true

services:
  radarr:
    image: linuxserver/radarr
    container_name: radarr
    ports:
      - 7878:7878
    volumes:
      - /srv/radarr/config:/config
      - /srv/jellyfin/data/movies:/movies
    restart: unless-stopped
    networks:
      servarrnetwork:
        ipv4_address: 172.39.0.4
