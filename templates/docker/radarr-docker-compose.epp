services:
  radarr:
    image: lscr.io/linuxserver/radarr:latest
    container_name: radarr
    # network_mode makes this container part of the Gluetun "pod"
    restart: unless-stopped
    ports:
      - "7878:7878"
    environment:
      - PUID=1000
      - PGID=1000
      - TZ=Europe/London
    volumes:
      - /srv/radarr/config:/config
      - /srv/jellyfin/data/movies:/movies
      - /srv/qbittorrent/data:/data
    # No ports here! They go in Gluetun.
