<%- | String $docker_user,
      String $docker_password,
| -%>
---
networks:
  servarrnetwork:
    name: servarrnetwork
    ipam:
      config:
        - subnet: 172.39.0.0/24

services:
  gluetun:
    image: qmcgaw/gluetun
    container_name: gluetun
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    networks:
      servarrnetwork:
        ipv4_address: 172.39.0.2
    ports:
      - 8000:8000 # gluetun web interface
      - 8080:8080 # qbittorrent web interface
      - 6881:6881 # qbittorrent torrent port
      - 6881:6881/udp # qbittorrent torrent port
      - 7878:7878 # radarr web interface
      - 9696:9696 # prowlarr
      - 8191:8191 # flaresolverr
    volumes:
      - /srv/gluetun:/gluetun
    environment:
      - VPN_SERVICE_PROVIDER=nordvpn
      - VPN_TYPE=openvpn
      - TZ=Europe/London
      - HEALTH_VPN_DURATION_INITIAL=120s
      - SERVER_COUNTRIES=Netherlands,Germany,Belgium,Switzerland
      - SERVER_CATEGORIES=Standard VPN servers
      - OPENVPN_USER=<%= $docker_user %>
      - OPENVPN_PASSWORD=<%= $docker_password %>
      - DOT=off
      - DNS_ADDRESS=1.1.1.1
      - FIREWALL_OUTBOUND_SUBNETS=172.39.0.2/32,172.39.0.1/32,172.39.0.0/24,192.168.1.0/24
    restart: unless-stopped
