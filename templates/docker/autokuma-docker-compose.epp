networks:
  servarr:
    external: true

services:
  autokuma:
    image: ghcr.io/bigboot/autokuma:latest
    container_name: autokuma
    restart: always
    environment:
      - AUTOKUMA__KUMA__URL=http://localhost:3001
      - AUTOKUMA__KUMA__USERNAME='craig'
      - AUTOKUMA__KUMA__PASSWORD='password123'
      - RUST_LOG=autokuma=trace,kuma_client=trace
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    networks:
      - servarr
