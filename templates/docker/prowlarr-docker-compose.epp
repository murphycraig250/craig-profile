networks:
  servarr:
    external: true
    
services:
  prowlarr:
    image: lscr.io/linuxserver/prowlarr:latest
    container_name: prowlarr
    networks:
      - servarr
    environment:
      - TZ=Europe/London
      - PUID=1050
      - PGID=1050
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /srv/prowlarr:/config
    restart: unless-stopped
    ports:
      - 9696:9696
