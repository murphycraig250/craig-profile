networks:
  servarr:
    external: true

services:
  lidarr:
    container_name: lidarr
    image: lscr.io/linuxserver/lidarr:latest
    networks:
      - servarr
    restart: unless-stopped
    volumes:
      - /etc/localtime:/etc/localtime:ro
      - /srv/lidarr/config:/config
      - /srv/lidarr/data:/data
      - /srv/jellyfin/data/music:/music
      - /srv/qbittorrent/data:/data
    environment:
      - TZ=Europe/London
      - PUID=1050
      - PGID=1050
    ports:
      - 8686:8686
